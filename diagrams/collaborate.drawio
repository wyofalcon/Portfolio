<?xml version="1.0" encoding="UTF-8"?>
<!-- Portfolio architecture diagram — collabor-AI-te -->
<mxfile host="app.diagrams.net" modified="2026-07-02T00:00:00.000Z" agent="portfolio" version="24.0.0">
<diagram name="Portfolio (T)" id="t-portfolio">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hdr-title" value="collabor-AI-te" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="20" width="1640" height="46" as="geometry" /></mxCell>
        <mxCell id="hdr-sub" value="One room where every dev and every AI shares the repo — with exactly one writer at a time." style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1"><mxGeometry x="30" y="72" width="1640" height="26" as="geometry" /></mxCell>
        <mxCell id="problem-strip" value="&lt;b style=&#x27;color:#9F2D43;letter-spacing:1px;font-size:11px;&#x27;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Two developers pairing with AI assistants hit a problem chat and screen-sharing do not solve: both AIs can read the repo, and if both can also write it, they clobber each other&amp;#x27;s edits. There is no shared switch for who gets to write right now.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="120" width="1380" height="80" as="geometry" /></mxCell>
        <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="222" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-1" value="&lt;span style=&#x27;font-size:10px;color:#526C96;letter-spacing:2px;&#x27;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Join the room&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;A VS Code panel + one Cloudflare&lt;br&gt;Durable Object. N devs, each&lt;br&gt;optionally bringing their own AI.&lt;br&gt;No pairing required.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="20" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-2" value="&lt;span style=&#x27;font-size:10px;color:#638860;letter-spacing:2px;&#x27;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Read is always open&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Every AI reads the full repo&lt;br&gt;and the full chat, always.&lt;br&gt;Understanding is never gated.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="365" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-3" value="&lt;span style=&#x27;font-size:10px;color:#796394;letter-spacing:2px;&#x27;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Write is a token&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Exactly one dev holds the&lt;br&gt;write-control switch. Flip it on&lt;br&gt;and you take it; theirs goes off.&lt;br&gt;The DO is the one truth.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="710" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-4" value="&lt;span style=&#x27;font-size:10px;color:#966B51;letter-spacing:2px;&#x27;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Optional hard lock&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;A PreToolUse hook blocks the&lt;br&gt;other AI&amp;#x27;s Write/Edit while you&lt;br&gt;hold the token. Convention&lt;br&gt;becomes an enforced lock.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1055" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-5" value="&lt;span style=&#x27;font-size:10px;color:#958769;letter-spacing:2px;&#x27;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Coordinate &amp;amp; settle&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Fuse Inference coordinates two&lt;br&gt;AIs (lead + offload). A networked&lt;br&gt;Tron duel settles standoffs,&lt;br&gt;posted as the decision of record.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1400" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-1" target="pitch-stage-2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-2" target="pitch-stage-3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-3" target="pitch-stage-4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-4" target="pitch-stage-5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="produces-label" value="↓   why it matters   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1"><mxGeometry x="700" y="455" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="outputs-header" value="Three views. One system." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="495" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A distributed-systems product, shipped&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;A VS Code extension, a Durable-Object backend, and an MCP server, solving a genuinely new coordination problem: human-plus-AI write contention on one repo. Real-time, and released (v0.6.0).&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“A new problem, cleanly solved.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A single source of truth, over WebSocket&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;The write lock, chat log, and roster live in one Durable Object (SQLite), fanned out over WebSocket. A model-agnostic MCP server exposes the control tools; an opt-in PreToolUse hook enforces the lock; the Tron sim is authoritative server-side. Zero-dependency extension.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“One truth, not two clients guessing.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;FOR TEAMS PAIRING WITH AI&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Bring your own AI. Never clobber.&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Everyone keeps reading, one side writes at a time, and a one-command invite wires a teammate&amp;#x27;s extension and AI in a single paste. Settle the standoff you can&amp;#x27;t talk out without a meeting.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“Two AIs, one repo, zero collisions.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;As every developer starts pairing with an AI, the missing primitive is not more chat. It is a shared, enforceable write-control token so humans and AIs can edit one repo without stepping on each other.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
<diagram name="Portfolio (P)" id="p-portfolio">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hdr-title" value="collabor-AI-te" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="20" width="1640" height="46" as="geometry" /></mxCell>
        <mxCell id="hdr-sub" value="A shared room for people and their AI helpers, where only one person can change the code at a time." style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1"><mxGeometry x="30" y="72" width="1640" height="26" as="geometry" /></mxCell>
        <mxCell id="problem-strip" value="&lt;b style=&#x27;color:#9F2D43;letter-spacing:1px;font-size:11px;&#x27;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;When two people work on the same code, each with an AI helper, all the helpers can read the code — but if two of them change it at once, they overwrite each other. There is no shared way to say &amp;quot;it is my turn to make changes right now.&amp;quot;&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="120" width="1380" height="80" as="geometry" /></mxCell>
        <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="222" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-1" value="&lt;span style=&#x27;font-size:10px;color:#526C96;letter-spacing:2px;&#x27;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Join the room&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Open a panel in your editor.&lt;br&gt;Anyone can join, with or&lt;br&gt;without an AI helper.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="20" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-2" value="&lt;span style=&#x27;font-size:10px;color:#638860;letter-spacing:2px;&#x27;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Everyone can read&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Every helper can always look&lt;br&gt;at the code and the chat.&lt;br&gt;Nobody is ever locked out&lt;br&gt;from understanding.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="365" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-3" value="&lt;span style=&#x27;font-size:10px;color:#796394;letter-spacing:2px;&#x27;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;One person writes&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;There is one &amp;quot;my turn&amp;quot; switch.&lt;br&gt;Flip yours on and it takes&lt;br&gt;the turn; the other person&amp;#x27;s&lt;br&gt;switch turns off.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="710" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-4" value="&lt;span style=&#x27;font-size:10px;color:#966B51;letter-spacing:2px;&#x27;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Lock it if you want&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;You can turn the switch into&lt;br&gt;a real lock, so the other&lt;br&gt;AI simply can&amp;#x27;t change files&lt;br&gt;when it is not its turn.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1055" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-5" value="&lt;span style=&#x27;font-size:10px;color:#958769;letter-spacing:2px;&#x27;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Team up, or settle it&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Two AIs can team up on one&lt;br&gt;plan. And if people can&amp;#x27;t agree,&lt;br&gt;a quick Tron game settles it&lt;br&gt;and posts the result.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1400" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-1" target="pitch-stage-2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-2" target="pitch-stage-3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-3" target="pitch-stage-4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-4" target="pitch-stage-5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="produces-label" value="↓   why it matters   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1"><mxGeometry x="700" y="455" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="outputs-header" value="What it means for you" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="495" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;IF YOU ARE HIRING&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A real, released tool&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;An editor add-on, a little cloud service, and an AI connector, all built to solve a brand-new problem: keeping two people and their AIs from overwriting each other. It works and it is released.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“Spotted a new problem and shipped a fix.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;IF YOU BUILD SOFTWARE&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;One shared source of truth&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;The turn-switch, the chat, and who is in the room all live in one place in the cloud and update live for everyone, instead of two apps guessing at each other. Any AI assistant can plug in.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“Everyone sees the same state.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;IF YOU PAIR WITH AI&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Bring your own AI, never clobber&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Everyone keeps reading, one person writes at a time, and a single copied command sets a teammate up in one step. No more talking over each other or overwriting each other&amp;#x27;s work.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“Two AIs, one project, no mess.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BIG IDEA&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;As everyone starts working alongside an AI, the missing piece is not more chat. It is one shared &amp;quot;my turn&amp;quot; switch so people and their AIs can share the same code without overwriting each other.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
