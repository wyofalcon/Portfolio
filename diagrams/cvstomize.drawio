    <diagram id="portfolio-cloud" name="Cloud Infrastructure">
        <mxGraphModel dx="1461" dy="788" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
            <root>
