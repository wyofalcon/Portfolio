        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;FOR RECRUITERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;See who they really are&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Resumes that show personality and stories, not just job titles. Easy to scan, always relevant to what you&amp;#x27;re hiring for.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“&amp;quot;This is way better than the same boring resume everyone sends.&amp;quot;”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;FOR DEVELOPERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Built the right way&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Clean React frontend, Node.js backend, PostgreSQL with vector search. AI-powered with Gemini, deployed on Google Cloud.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“&amp;quot;This is how you build an AI product the right way.&amp;quot;”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;FOR EVERYONE ELSE&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Your story, organized&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Talk about your work once. The AI remembers and uses it for every job. Your professional page stays current without extra work.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“&amp;quot;I just talked about my work and it made me a great resume.&amp;quot;”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;When AI can do anything, showing who you are — not just what you know — is what gets you hired.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
