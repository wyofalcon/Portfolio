                    <mxGeometry x="400" y="30" width="800" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-subtitle" value="Serverless Architecture on Google Cloud Platform with Full CI/CD Automation" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=2;fontColor=#455A64" parent="cloud-1" vertex="1">
                    <mxGeometry x="400" y="80" width="800" height="30" as="geometry"/>
