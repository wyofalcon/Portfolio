                    <mxGeometry x="1330" y="380" width="180" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-vertex" value="&lt;b style=&quot;font-size: 15px;&quot;&gt;Vertex AI&lt;/b&gt;&lt;hr&gt;• Gemini 2.5 Pro&lt;br&gt;• Gemini 2.0 Flash&lt;br&gt;• text-embedding-004&lt;br&gt;• Managed inference" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFA726;strokeColor=#F57C00;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="1130" y="530" width="180" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-secrets" value="&lt;b style=&quot;font-size: 15px;&quot;&gt;Secret Manager&lt;/b&gt;&lt;hr&gt;• Encrypted secrets&lt;br&gt;• Version control&lt;br&gt;• IAM-controlled access" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FF9800;strokeColor=#F57C00;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="1330" y="530" width="180" height="100" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-local" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#7B1FA2;strokeWidth=3;verticalAlign=top;fontSize=16;fontStyle=1" parent="cloud-1" vertex="1">
                    <mxGeometry x="100" y="480" width="730" height="210" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-local-label" value="LOCAL DEVELOPMENT (Docker Compose)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#7B1FA2" parent="cloud-1" vertex="1">
                    <mxGeometry x="120" y="490" width="860" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-docker" value="&lt;b style=&quot;font-size: 14px;&quot;&gt;Containerized Services:&lt;/b&gt;&lt;hr&gt;• &lt;b&gt;database&lt;/b&gt; - PostgreSQL 15 + pgvector&lt;br&gt;• &lt;b&gt;redis&lt;/b&gt; - Cache layer&lt;br&gt;• &lt;b&gt;backend&lt;/b&gt; - Node.js API with hot reload&lt;br&gt;• &lt;b&gt;frontend&lt;/b&gt; - React dev server&lt;br&gt;• &lt;b&gt;firebase-emulator&lt;/b&gt; - Local auth (cost-free)&lt;br&gt;• &lt;b&gt;storybook&lt;/b&gt; - Component library&lt;br&gt;&lt;br&gt;&lt;b&gt;Dev Features:&lt;/b&gt; Mock AI mode • Dev auth bypass • Volume mounts for hot reload" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="110" y="520" width="680" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="edge-github-cicd" value="Push to main" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;fontSize=13;fontStyle=1;strokeColor=#388E3C" parent="cloud-1" source="cloud-dev" target="cloud-cicd" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="edge-cicd-gcp" value="Deploy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeWidth=3;fontSize=13;fontStyle=1;strokeColor=#1976D2" parent="cloud-1" source="cloud-cicd" target="cloud-gcp" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-highlights" value="&lt;b style=&quot;font-size: 18px;&quot;&gt;Infrastructure Achievements&lt;/b&gt;&lt;hr style=&quot;border-top: 2px solid #263238;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;b style=&quot;font-size: 14px; color: #1976D2;&quot;&gt;☁️ Serverless &amp; Auto-Scaling&lt;/b&gt;&lt;br&gt;• Zero infrastructure management with Cloud Run&lt;br&gt;• Automatic horizontal scaling from 0 to 10 instances based on load&lt;br&gt;• Pay-per-use pricing model (cost-effective for variable traffic)&lt;br&gt;• Built-in load balancing and HTTPS termination&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size: 14px; color: #388E3C;&quot;&gt;🔄 DevOps Excellence&lt;/b&gt;&lt;br&gt;• Fully automated CI/CD pipeline with GitHub Actions&lt;br&gt;• Zero-downtime deployments with rolling updates&lt;br&gt;• Comprehensive test suite (unit, integration, E2E) runs on every commit&lt;br&gt;• Infrastructure as Code approach for reproducibility&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size: 14px; color: #F57C00;&quot;&gt;🔐 Security &amp; Compliance&lt;/b&gt;&lt;br&gt;• All secrets managed via GCP Secret Manager (never committed to Git)&lt;br&gt;• IAM-based access control with least-privilege principle&lt;br&gt;• GDPR-compliant data handling with cascading deletes&lt;br&gt;• Automated security scanning in CI/CD pipeline&lt;br&gt;&lt;br&gt;&lt;b style=&quot;font-size: 14px; color: #7B1FA2;&quot;&gt;💰 Cost Optimization&lt;/b&gt;&lt;br&gt;• Scale-to-zero during idle periods (no wasted compute)&lt;br&gt;• Local dev environment replicates production without GCP costs&lt;br&gt;• Mock AI mode for cost-free development and testing&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#263238;strokeWidth=3;align=left;fontSize=13;spacingLeft=20;spacingTop=10;verticalAlign=top;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="800" y="740" width="510" height="440" as="geometry"/>
                </mxCell>
            </root>
