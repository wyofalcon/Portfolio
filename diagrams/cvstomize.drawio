                    <mxGeometry x="120" y="160" width="360" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-github" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;GitHub Repository&lt;/b&gt;&lt;hr&gt;Branch Strategy:&lt;br&gt;• &lt;b&gt;main&lt;/b&gt; → Production&lt;br&gt;• &lt;b&gt;develop&lt;/b&gt; → Testing&lt;br&gt;• &lt;b&gt;feature/*&lt;/b&gt; → Development&lt;br&gt;&lt;br&gt;Git Hooks:&lt;br&gt;• Pre-commit linting&lt;br&gt;• Automated testing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#388E3C;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="130" y="210" width="340" height="180" as="geometry"/>
