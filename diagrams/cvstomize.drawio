                <mxCell id="cloud-cicd" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=3;verticalAlign=top;fontSize=16;fontStyle=1" parent="cloud-1" vertex="1">
                    <mxGeometry x="640" y="160" width="340" height="300" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-cicd-label" value="CI/CD PIPELINE" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1976D2" parent="cloud-1" vertex="1">
                    <mxGeometry x="620" y="160" width="360" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-actions" value="&lt;b style=&quot;font-size: 16px;&quot;&gt;GitHub Actions Workflow&lt;/b&gt;&lt;hr&gt;&lt;b&gt;Automated Testing:&lt;/b&gt;&lt;br&gt;• Jest (Backend unit + integration tests)&lt;br&gt;• Playwright (E2E tests)&lt;br&gt;• ESLint (Code quality)&lt;br&gt;&lt;br&gt;&lt;b&gt;Build Pipeline:&lt;/b&gt;&lt;br&gt;• Multi-stage Docker builds&lt;br&gt;• Push to Google Container Registry&lt;br&gt;• Security scanning&lt;br&gt;&lt;br&gt;&lt;b&gt;Deployment:&lt;/b&gt;&lt;br&gt;• Zero-downtime rolling updates&lt;br&gt;• Automated smoke tests&lt;br&gt;• Rollback on failure" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1976D2;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="665" y="190" width="270" height="250" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-gcp" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;strokeWidth=3;verticalAlign=top;fontSize=16;fontStyle=1" parent="cloud-1" vertex="1">
                    <mxGeometry x="1100" y="150" width="440" height="500" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-gcp-label" value="GOOGLE CLOUD PLATFORM" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#F57C00" parent="cloud-1" vertex="1">
                    <mxGeometry x="1120" y="160" width="400" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-run" value="&lt;b style=&quot;font-size: 15px;&quot;&gt;Cloud Run (Serverless Containers)&lt;/b&gt;&lt;hr&gt;&lt;b&gt;API Service:&lt;/b&gt;&lt;br&gt;• 1 vCPU, 1Gi memory&lt;br&gt;• Auto-scale: 0-10 instances&lt;br&gt;• Pay-per-use pricing&lt;br&gt;&lt;br&gt;&lt;b&gt;Frontend Service:&lt;/b&gt;&lt;br&gt;• 1 vCPU, 512Mi memory&lt;br&gt;• Auto-scale: 0-2 instances&lt;br&gt;• Static asset serving (Nginx)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#F57C00;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
                    <mxGeometry x="1130" y="190" width="300" height="180" as="geometry"/>
                </mxCell>
                <mxCell id="cloud-sql" value="&lt;b style=&quot;font-size: 15px;&quot;&gt;Cloud SQL (Managed PostgreSQL)&lt;/b&gt;&lt;hr&gt;• PostgreSQL 15 with pgvector&lt;br&gt;• High Availability (HA) configuration&lt;br&gt;• Automated daily backups&lt;br&gt;• Private IP connectivity&lt;br&gt;• Point-in-time recovery" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFCC80;strokeColor=#F57C00;strokeWidth=2;align=left;fontSize=15;spacingLeft=15;fontStyle=0" parent="cloud-1" vertex="1">
