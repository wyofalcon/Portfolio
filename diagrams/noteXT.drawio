  <diagram name="Journey" id="journey">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1600" pageHeight="1204" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hdr-title" value="NoteXT — User Journey" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#E5E7EB;fontSize=22;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="60" y="18" width="1480" height="34" as="geometry" /></mxCell>
        <mxCell id="hdr-sub" value="How it works — capture once, we handle the rest." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontColor=#9CA3AF;fontSize=12;" parent="1" vertex="1"><mxGeometry x="60" y="54" width="1120" height="22" as="geometry" /></mxCell>
        <mxCell id="hdr-hint" value="Hover any step for details" style="text;html=1;strokeColor=none;fillColor=none;align=right;verticalAlign=middle;fontColor=#9CA3AF;fontSize=11;fontStyle=2;" parent="1" vertex="1"><mxGeometry x="60" y="80" width="1480" height="22" as="geometry" /></mxCell>
        <mxCell id="hdr-actor" value="&lt;b&gt;You&lt;/b&gt;" style="shape=actor;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" vertex="1"><mxGeometry x="770" y="110" width="60" height="70" as="geometry" /></mxCell>
        <mxCell id="lg-user" value="What you do" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#89B4FA;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;spacingLeft=10;spacingRight=10;" parent="1" vertex="1"><mxGeometry x="1180" y="110" width="140" height="32" as="geometry" /></mxCell>
        <mxCell id="lg-app" value="What NoteXT does" style="rounded=1;whiteSpace=wrap;html=1;arcSize=12;shadow=1;fillColor=#A6E3A1;strokeColor=none;fontColor=#FFFFFF;fontSize=12;fontStyle=1;spacingLeft=10;spacingRight=10;" parent="1" vertex="1"><mxGeometry x="1340" y="110" width="200" height="32" as="geometry" /></mxCell>
        <mxCell id="spine" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#CCCCCC;strokeColor=none;" parent="1" vertex="1"><mxGeometry x="798" y="240" width="4" height="826" as="geometry" /></mxCell>
        <mxCell id="step-capture" value="&lt;b&gt;Capture any thought, anywhere&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Text it from a locked phone. Type it in the app. Snap a screenshot. Voice memo. Share from another app. NoteXT meets you wherever the thought happens — nothing new to learn.

What you&#x27;ll see: A two-second interaction. No menus, no folders, no tags.

Tips: SMS works on a flip phone · Screenshots become notes automatically · Works offline — syncs when back online" vertex="1"><mxGeometry x="60" y="200" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-capture" value="&lt;b&gt;1&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#89B4FA;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="218" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-understand" value="&lt;b&gt;Reads and sorts it instantly&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Our AI reads the note, files it under the right category, and pulls out anything actionable — a deadline, a place, a person, a shopping list. No sorting, no tagging, no setup.

What you&#x27;ll see: The note appears already organized. You never had to think about where it goes.

Tips: Runs on-device when possible (free + private) · Falls back to cloud only when needed · You stay in control — every category is editable" vertex="1"><mxGeometry x="860" y="318" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-understand" value="&lt;b&gt;2&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#A6E3A1;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="336" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-learn" value="&lt;b&gt;Quietly learns your rhythm&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Over weeks, NoteXT builds a private picture of your routines: when you wake, where you shop, who you message, what kind of notes you write. We only learn what a thoughtful human assistant would notice — never your browsing, never your searches.

What you&#x27;ll see: Nothing on the surface. The intelligence shows up later, in better-timed reminders.

Tips: Five-axis profile: People, Places, Routines, Habits, Style · Fully visible to you — you can see and delete every learned pattern · Privacy is the product, not a setting" vertex="1"><mxGeometry x="860" y="436" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-learn" value="&lt;b&gt;3&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#A6E3A1;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="454" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-live" value="&lt;b&gt;Go about your day&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="The whole point: capture once, then stop carrying it in your head. No checklist to revisit, no calendar to maintain, no app to babysit.

What you&#x27;ll see: Your phone stays quiet. Your mind stays clear.

Tips: No notifications until something actually matters · No daily-digest spam · Forgetting is allowed — the system remembers" vertex="1"><mxGeometry x="60" y="554" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-live" value="&lt;b&gt;4&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#89B4FA;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="572" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-moment" value="&lt;b&gt;Picks the right moment to surface it&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Routines, location, and what&#x27;s on the note all decide when to remind you. A grocery list triggers near the store. A Friday todo triggers Friday morning. A birthday note triggers the night before.

What you&#x27;ll see: A reminder that feels suspiciously well-timed.

Tips: Time + place + person + content, all weighted together · Learns from what you ignored vs. what you acted on · Gets noticeably sharper after the first month" vertex="1"><mxGeometry x="860" y="672" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-moment" value="&lt;b&gt;5&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#A6E3A1;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="690" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-nudge" value="&lt;b&gt;Nudges gently first — escalates only if needed&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Push first, because it&#x27;s quiet and free. If you don&#x27;t respond and the deadline matters, it sends a text. If you still don&#x27;t respond, it calls you. Any reply at any step — a tap, a text, just doing the thing — cancels the rest of the chain.

What you&#x27;ll see: A friendly reminder. Then nothing, unless it really matters.

Tips: Reverse escalation — lightest touch first · Push is free; SMS and calls cost us, so we save them for when they count · You&#x27;re never harassed by your own reminders" vertex="1"><mxGeometry x="860" y="790" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-nudge" value="&lt;b&gt;6&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#A6E3A1;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="808" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-act" value="&lt;b&gt;Reply, tap, or just do it — done&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Acknowledge however is easiest. A &#x27;done&#x27; SMS, a tap on the push, completing the action in real life. NoteXT closes the loop and gets out of the way.

What you&#x27;ll see: The note quietly archives itself. No celebration screen, no streak counter.

Tips: Replies parse naturally — &#x27;done&#x27;, &#x27;later&#x27;, &#x27;tomorrow at 3&#x27; all work · Snooze is one tap or one word · Completed notes feed back into your profile" vertex="1"><mxGeometry x="60" y="908" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-act" value="&lt;b&gt;7&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#89B4FA;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="926" width="44" height="44" as="geometry" /></mxCell>
        <mxCell id="step-learn-loop" value="&lt;b&gt;Gets sharper with every note&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;shadow=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#D1D5DB;fontSize=11;" parent="1" tooltip="Every captured note, every dismissed reminder, every on-time completion feeds the profile. The system that knows you in week 1 becomes uncannily accurate by month 3 — a moat that grows quietly with use.

What you&#x27;ll see: Reminders that feel less like notifications and more like a friend who remembers things for you.

Tips: Compounding accuracy = compounding retention · Network-effect-free moat — grows from your data alone · Your profile travels with you across devices" vertex="1"><mxGeometry x="860" y="1026" width="680" height="80" as="geometry" /></mxCell>
        <mxCell id="badge-step-learn-loop" value="&lt;b&gt;8&lt;/b&gt;" style="ellipse;whiteSpace=wrap;html=1;shadow=1;fillColor=#A6E3A1;strokeColor=#FFFFFF;strokeWidth=2;fontColor=#FFFFFF;fontSize=14;fontStyle=1;" parent="1" vertex="1"><mxGeometry x="778" y="1044" width="44" height="44" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
