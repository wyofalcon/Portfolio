        <mxCell id="hdr-sub" value="Capture once. The phone handles the rest." style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1"><mxGeometry x="30" y="72" width="1640" height="26" as="geometry" /></mxCell>
        <mxCell id="problem-strip" value="&lt;b style=&#x27;color:#9F2D43;letter-spacing:1px;font-size:11px;&#x27;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Every notes app makes you do the boring part — sorting, tagging, remembering to come back.&lt;br&gt;Life is faster than that, so the lists pile up and the things you needed to do slip through.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="120" width="1380" height="80" as="geometry" /></mxCell>
        <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="222" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-1" value="&lt;span style=&#x27;font-size:10px;color:#526C96;letter-spacing:2px;&#x27;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Capture anywhere&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Text it from a flip phone.&lt;br&gt;Snap a screenshot. Say it.&lt;br&gt;Share from any app.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="20" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-2" value="&lt;span style=&#x27;font-size:10px;color:#638860;letter-spacing:2px;&#x27;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Reads it instantly&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Files it for you. Picks out&lt;br&gt;anything you&amp;#x27;ll need to act on —&lt;br&gt;a deadline, a list, a place.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="365" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-3" value="&lt;span style=&#x27;font-size:10px;color:#796394;letter-spacing:2px;&#x27;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Quietly learns your rhythm&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Picks up only what a thoughtful&lt;br&gt;friend would notice. You can see&lt;br&gt;and delete every learned thing.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="710" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-4" value="&lt;span style=&#x27;font-size:10px;color:#966B51;letter-spacing:2px;&#x27;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Reminds you at the right moment&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;A gentle nudge first.&lt;br&gt;A text only if you didn&amp;#x27;t see it.&lt;br&gt;A call only if it really matters.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1055" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-5" value="&lt;span style=&#x27;font-size:10px;color:#958769;letter-spacing:2px;&#x27;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;You act — done&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Reply &amp;#x27;done&amp;#x27;, tap, or finish&lt;br&gt;the thing. The note files itself.&lt;br&gt;The app gets out of your way.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1400" y="265" width="280" height="170" as="geometry" /></mxCell>
