<diagram name="Portfolio (T)" id="t-portfolio">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hdr-title" value="NoteXT" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="20" width="1640" height="46" as="geometry" /></mxCell>
        <mxCell id="hdr-sub" value="Capture once. The phone handles the rest." style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1"><mxGeometry x="30" y="72" width="1640" height="26" as="geometry" /></mxCell>
        <mxCell id="problem-strip" value="&lt;b style=&#x27;color:#9F2D43;letter-spacing:1px;font-size:11px;&#x27;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Every productivity app makes you do the work — sort, tag, file, then remember to act on it.&lt;br&gt;Modern life produces more thoughts than any taxonomy can hold, so the notes pile up and the deadlines slip.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="120" width="1380" height="80" as="geometry" /></mxCell>
        <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="222" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-1" value="&lt;span style=&#x27;font-size:10px;color:#526C96;letter-spacing:2px;&#x27;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Capture anywhere&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Text it from a flip phone.&lt;br&gt;Snap a screenshot. Say it.&lt;br&gt;Share from any app.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="20" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-2" value="&lt;span style=&#x27;font-size:10px;color:#638860;letter-spacing:2px;&#x27;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;AI sorts instantly&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;On-device first, cloud only when needed.&lt;br&gt;Files the note. Pulls out the date,&lt;br&gt;place, person, list — automatically.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="365" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-3" value="&lt;span style=&#x27;font-size:10px;color:#796394;letter-spacing:2px;&#x27;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Profile learns quietly&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;5 axes — People, Places, Routines,&lt;br&gt;Habits, Style. Visible to you.&lt;br&gt;Narrower than any incumbent.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="710" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-4" value="&lt;span style=&#x27;font-size:10px;color:#966B51;letter-spacing:2px;&#x27;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Right-time, right-channel&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Push first (free, quiet).&lt;br&gt;SMS if it matters.&lt;br&gt;Call as the ceiling.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1055" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-5" value="&lt;span style=&#x27;font-size:10px;color:#958769;letter-spacing:2px;&#x27;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Loop closes itself&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Reply, tap, or just do it.&lt;br&gt;Note archives. Profile sharpens.&lt;br&gt;The moat compounds.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1400" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-1" target="pitch-stage-2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-2" target="pitch-stage-3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-3" target="pitch-stage-4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-4" target="pitch-stage-5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="produces-label" value="↓   produces   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1"><mxGeometry x="700" y="455" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="outputs-header" value="Three audiences. One artifact." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="495" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;FOR INVESTORS &amp;amp; RECRUITERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A moat made of trust, not data hoarding&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Privacy-as-product.&lt;br&gt;Narrower tracking than every incumbent, full visibility into every learned row, autonomous alerting that gets sharper with use — a network-effect-free retention curve that compounds quietly per user.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“I get the wedge in 30 seconds.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Mobile-primary, on-device-first, batched-AI&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Native Expo app is the daily surface; PWA stays for billing + auth-handoff.&lt;br&gt;Apple Foundation Models / Gemini Nano on-device, Vertex AI as the cloud floor.&lt;br&gt;30s server batch keeps cost predictable. Patterns mined nightly, not per-note.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“I can read this stack in one diagram.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;FOR NON-TECHNICAL AUDIENCES&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Your phone, finally quiet&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;No daily-digest spam. No notifications until something actually matters.&lt;br&gt;Forgetting is allowed — the system remembers, the right way, at the right time, and gets noticeably sharper after the first month.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“It feels like an assistant who knows me.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;The competitive moat isn&amp;#x27;t a smarter model — it&amp;#x27;s the smallest, most observable user-model that grows with use.&lt;br&gt;Privacy is the product. Autonomy is the wedge. Compounding accuracy = compounding retention.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
