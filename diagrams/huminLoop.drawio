                <mxCell id="pitch-aud-1" value="&lt;span style=&#39;font-size:11px;color:#526C96;letter-spacing:2px;&#39;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Shipped, cross-platform, opinionated&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;A working app for Windows, Linux, and Mac, built solo by one developer. The installers are already on GitHub.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#526C96;font-style:italic;&#39;&gt;“Wait, one person built this whole thing?”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="30" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-2" value="&lt;span style=&#39;font-size:11px;color:#638860;letter-spacing:2px;&#39;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Bridge between screen and AI&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;Built on Electron with a database that auto-picks Postgres or SQLite. Talks to Gemini for AI. Includes a server that hooks into Claude Code or other AI editors.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#638860;font-style:italic;&#39;&gt;“I want to copy this and connect it to my AI tools.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="590" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-3" value="&lt;span style=&#39;font-size:11px;color:#796394;letter-spacing:2px;&#39;&gt;FOR ANYONE ELSE&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Like a sticky note, but smarter&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;You take a screenshot, write a quick note, and the app sorts it. If you use an AI helper, it writes the fix-it message for you.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#796394;font-style:italic;&#39;&gt;“It&amp;#x27;s Pinterest for things I want to fix later.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="1150" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="bet-footer" value="&lt;b style=&#39;color:#3F5566;letter-spacing:1px;font-size:11px;&#39;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;AI tools can write code fast — but you still have to tell them what to fix. HuminLoop makes that handoff take seconds, so you don&amp;#x27;t lose your train of thought.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
