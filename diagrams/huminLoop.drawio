                <mxCell id="hdr-title" value="HuminLoop" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="20" width="1640" height="46" as="geometry"/>
                </mxCell>
                <mxCell id="hdr-sub" value="Keeping humans in the loop — AI-powered knowledge capture for developers who build with AI" style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1">
                    <mxGeometry x="30" y="72" width="1640" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="problem-strip" value="&lt;b style=&#39;color:#9F2D43;letter-spacing:1px;font-size:11px;&#39;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;Developers using AI coding tools lose context every time a new bug catches their eye. Switching apps to retype what they just saw burns the focus they had — especially brutal for ADHD brains.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="120" width="1380" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="222" width="1640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-1" value="&lt;span style=&#39;font-size:10px;color:#526C96;letter-spacing:2px;&#39;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Screenshot or annotate&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Clipboard watcher polls 1s for new images.&lt;br&gt;Or draw red/green/pink on screen with the toolbar overlay.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="20" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-2" value="&lt;span style=&#39;font-size:10px;color:#638860;letter-spacing:2px;&#39;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Capture window context&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Active window title, process, and repo path captured automatically (Win32 / xdotool / gdbus).&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="365" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-3" value="&lt;span style=&#39;font-size:10px;color:#796394;letter-spacing:2px;&#39;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Rules + Gemini sort&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;7-strategy rule chain runs instantly.&lt;br&gt;Gemini 2.5 Flash enriches in the background — summary, tags, project match.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="710" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-4" value="&lt;span style=&#39;font-size:10px;color:#966B51;letter-spacing:2px;&#39;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Generate coding prompt&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Annotation colors decoded (red=remove, green=add, pink=ref).&lt;br&gt;Prompt enriched with SESSION.md + AUDIT_LOG context.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1055" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-5" value="&lt;span style=&#39;font-size:10px;color:#958769;letter-spacing:2px;&#39;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Send to IDE via MCP&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Stages IDE_PROMPT.md to .ai-workflow/.&lt;br&gt;MCP server delivers one-shot to Claude Code or Gemini CLI.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1400" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-1" target="pitch-stage-2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
