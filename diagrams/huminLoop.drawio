                <mxCell id="produces-label" value="↓   produces   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1">
                    <mxGeometry x="700" y="455" width="300" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="outputs-header" value="Three audiences. One artifact." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="495" width="1640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-1" value="&lt;span style=&#39;font-size:11px;color:#526C96;letter-spacing:2px;&#39;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Shipped, cross-platform, opinionated&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;An ADHD-friendly desktop app shipping NSIS / AppImage / deb / dmg installers from a single repo. Vanilla JS renderer. Native JWT for Vertex AI — no SDK dependencies. Multi-agent dev workflow baked in.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#526C96;font-style:italic;&#39;&gt;“Wait, this guy actually shipped this?”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="30" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-2" value="&lt;span style=&#39;font-size:11px;color:#638860;letter-spacing:2px;&#39;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Bridge between screen and AI&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;Electron 33, dual-DB (Postgres or SQLite auto-fallback), Gemini 2.5 Flash, and an MCP server with 19 tools that lets any AI IDE talk to your clip database. Send-to-IDE uses a one-shot file bridge — staged and consumed atomically.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#638860;font-style:italic;&#39;&gt;“I want to fork this and wire it into Claude Code.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="590" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-3" value="&lt;span style=&#39;font-size:11px;color:#796394;letter-spacing:2px;&#39;&gt;FOR ANYONE ELSE&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Like a sticky note, but smarter&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;You see something that needs fixing. You snip a screenshot, jot what&amp;#x27;s wrong, and the app organizes it for you. If you have an AI helper, it writes the instruction so you can act on it later.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#796394;font-style:italic;&#39;&gt;“It&amp;#x27;s Pinterest for things I want to fix later.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="1150" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="bet-footer" value="&lt;b style=&#39;color:#3F5566;letter-spacing:1px;font-size:11px;&#39;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;Knowledge capture is the missing layer between AI coding tools and a developer&amp;#x27;s flow state. Every screenshot is a bug report waiting to be acted on — HuminLoop closes the loop in seconds, not minutes.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="800" width="1380" height="80" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
