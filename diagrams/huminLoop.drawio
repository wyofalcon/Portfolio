                </mxCell>
                <mxCell id="pitch-stage-1" value="&lt;span style=&#39;font-size:10px;color:#526C96;letter-spacing:2px;&#39;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;See an issue, mark it&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;HuminLoop notices any screenshot you take.&lt;br&gt;Or you scribble colors on the screen to mark what&amp;#x27;s wrong.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="20" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-2" value="&lt;span style=&#39;font-size:10px;color:#638860;letter-spacing:2px;&#39;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;App grabs the context&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;It also remembers what app and file you were looking at when you took the shot.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="365" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-3" value="&lt;span style=&#39;font-size:10px;color:#796394;letter-spacing:2px;&#39;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;AI sorts and tags it&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Sorts your note by project, adds tags, and writes a fix-it summary — without you doing anything.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="710" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-4" value="&lt;span style=&#39;font-size:10px;color:#966B51;letter-spacing:2px;&#39;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Writes the AI prompt for you&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Turns your scribble plus a one-line note into a ready-to-paste instruction for an AI coder.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1055" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-5" value="&lt;span style=&#39;font-size:10px;color:#958769;letter-spacing:2px;&#39;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Hands it to your AI tool&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Your AI coding tool picks it up and starts fixing — you never broke focus.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
