                <mxCell id="hdr-sub" value="Keeping humans in the loop — AI-powered knowledge capture for developers who build with AI" style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1">
                    <mxGeometry x="30" y="72" width="1640" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="problem-strip" value="&lt;b style=&#39;color:#9F2D43;letter-spacing:1px;font-size:11px;&#39;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;When you spot a bug while coding with AI, you have to stop, switch apps, and retype what you saw. That breaks your focus every single time.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="120" width="1380" height="80" as="geometry"/>
