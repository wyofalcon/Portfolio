<diagram name="Portfolio (T)" id="t-portfolio">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
