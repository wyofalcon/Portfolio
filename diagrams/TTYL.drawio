                <mxCell id="s-end" value="&lt;b&gt;You close the chat&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The chat ends and the floating tile drops the row." vertex="1">
