                <mxCell id="produces-label" value="↓   produces   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1">
                    <mxGeometry x="700" y="455" width="300" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="outputs-header" value="Three audiences. One artifact." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="495" width="1640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-1" value="&lt;span style=&#39;font-size:11px;color:#526C96;letter-spacing:2px;&#39;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;A small productivity tool, built top to bottom&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;Shows range: a script that listens to events, a file format for sharing state, a floating window on Windows, an installer, and a plugin — all built solo as one piece.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#526C96;font-style:italic;&#39;&gt;“Solo dev who can ship a desktop app, a plugin, and a marketplace listing in one weekend.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="30" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-2" value="&lt;span style=&#39;font-size:11px;color:#638860;letter-spacing:2px;&#39;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Built to keep working when things break&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;Handles the messy cases: missing tools, crashed terminals, several copies running side-by-side. The kind of edge cases most demos quietly skip.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#638860;font-style:italic;&#39;&gt;“I see how this stays correct when something obvious breaks — that&amp;#x27;s the part most demos skip.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="590" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-3" value="&lt;span style=&#39;font-size:11px;color:#796394;letter-spacing:2px;&#39;&gt;FOR NON-TECHNICAL AUDIENCES&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;A floating timer that never lies&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;One small tile sits on top of every window. It shows a row for each Claude conversation, glows when one finishes, and clicking a row jumps you straight to that project. Nothing else to learn.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#796394;font-style:italic;&#39;&gt;“Oh — the green pill turning red is when I should reply. Got it.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="1150" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="bet-footer" value="&lt;b style=&#39;color:#3F5566;letter-spacing:1px;font-size:11px;&#39;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;The best small tools are the ones one person builds for themself. This one shows the countdown and flashes when Claude is done — that&amp;#x27;s the whole pitch.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="800" width="1380" height="80" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>