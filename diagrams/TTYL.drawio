                </mxCell>
                <mxCell id="s-click" value="&lt;b&gt;You click and it jumps to your editor&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="Clicking the row brings the right VSCode window to the front." vertex="1">
