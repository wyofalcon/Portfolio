                    <mxGeometry x="1268" y="156" width="291" height="1048" as="geometry"/>
                </mxCell>
                <mxCell id="s-start" value="&lt;b&gt;A new Claude chat opens&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The first thing that happens when you start chatting." vertex="1">
                    <mxGeometry x="54" y="170" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-route1" value="&lt;b&gt;Decide what just happened&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#FAB387;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The script looks at what kind of thing just happened and reacts." vertex="1">
                    <mxGeometry x="361" y="254" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-write1" value="&lt;b&gt;Save &amp;#x27;no cache yet&amp;#x27; to the file&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#F9E2AF;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The chat now has its own little status file." vertex="1">
                    <mxGeometry x="668" y="338" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-prompt" value="&lt;b&gt;You hit enter on a prompt&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="Now Claude is doing work — the cache is being topped up." vertex="1">
                    <mxGeometry x="54" y="422" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-write2" value="&lt;b&gt;Save &amp;#x27;working&amp;#x27; to the file&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#F9E2AF;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The status file now says Claude is busy." vertex="1">
                    <mxGeometry x="668" y="506" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-render1" value="&lt;b&gt;Status bar shows the spinning icon&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#CBA6F7;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="Your status bar now shows that Claude is working." vertex="1">
                    <mxGeometry x="975" y="590" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-stop" value="&lt;b&gt;Claude finishes its reply&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#89B4FA;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="Claude is done thinking and writing for this turn." vertex="1">
                    <mxGeometry x="54" y="674" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-write3" value="&lt;b&gt;Save &amp;#x27;waiting&amp;#x27; + the time&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#F9E2AF;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The file now records when Claude finished, so the countdown can start." vertex="1">
                    <mxGeometry x="668" y="758" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-render2" value="&lt;b&gt;Countdown ticks down in your status bar&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#CBA6F7;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="You see the colour change as time runs out before the cache expires." vertex="1">
                    <mxGeometry x="975" y="842" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-poll" value="&lt;b&gt;Desktop app notices the change&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#CBA6F7;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The floating tile is also reading the file and notices the update." vertex="1">
                    <mxGeometry x="975" y="842" width="263" height="56" as="geometry"/>
                </mxCell>
                <mxCell id="s-flash" value="&lt;b&gt;The row flashes to grab your attention&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;shadow=1;fillColor=#FFFFFF;strokeColor=#A6E3A1;strokeWidth=1.5;fontColor=#333333;fontSize=14;fontStyle=1;" parent="1" tooltip="The little pill on screen lights up so you notice Claude is done." vertex="1">
