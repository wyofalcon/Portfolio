<mxfile host="65bd71144e">
    <diagram name="Portfolio (T)" id="t-portfolio">
        <mxGraphModel dx="1461" dy="788" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" background="#1a2235" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="hdr-title" value="TTYL — Talk To You Later" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="20" width="1640" height="46" as="geometry"/>
                </mxCell>
                <mxCell id="hdr-sub" value="Claude Code plugin: live prompt-cache TTL in the status line, plus an optional Windows desktop tile that flashes when Claude finishes a turn" style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1">
                    <mxGeometry x="30" y="72" width="1640" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="problem-strip" value="&lt;b style=&#39;color:#9F2D43;letter-spacing:1px;font-size:11px;&#39;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;Anthropic&amp;#x27;s prompt cache lapses every 5 minutes. Let it expire and the next prompt re-pays full input-token cost. Across parallel Claude Code sessions on different virtual desktops, it&amp;#x27;s easy to lose track of which is about to lapse — or which one just finished talking to you.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="120" width="1380" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="222" width="1640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-1" value="&lt;span style=&#39;font-size:10px;color:#526C96;letter-spacing:2px;&#39;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Hook fires&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;SessionStart, UserPromptSubmit,&lt;br&gt;PreCompact, Stop, SessionEnd —&lt;br&gt;all route to one bash script.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="20" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-2" value="&lt;span style=&#39;font-size:10px;color:#638860;letter-spacing:2px;&#39;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;State on disk&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;~/.claude/cache-timers/&lt;br&gt;&amp;lt;session-id&amp;gt;.json&lt;br&gt;idle · active · none + epoch&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="365" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-3" value="&lt;span style=&#39;font-size:10px;color:#796394;letter-spacing:2px;&#39;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Watcher reads&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;PyQt6 desktop tile polls&lt;br&gt;every file at 1 Hz; psutil&lt;br&gt;evicts dead PIDs.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="710" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-4" value="&lt;span style=&#39;font-size:10px;color:#966B51;letter-spacing:2px;&#39;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Tile renders&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;One row per session.&lt;br&gt;Green → yellow → red →&lt;br&gt;expired. Flash on Stop.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1055" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-5" value="&lt;span style=&#39;font-size:10px;color:#958769;letter-spacing:2px;&#39;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Click to focus&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Left-click any row →&lt;br&gt;SetForegroundWindow brings&lt;br&gt;that VSCode to the top.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1400" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-1" target="pitch-stage-2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-2" target="pitch-stage-3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-3" target="pitch-stage-4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-4" target="pitch-stage-5" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="produces-label" value="↓   produces   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1">
                    <mxGeometry x="700" y="455" width="300" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="outputs-header" value="Three audiences. One artifact." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="495" width="1640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-1" value="&lt;span style=&#39;font-size:11px;color:#526C96;letter-spacing:2px;&#39;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;A Windows-native productivity tool, end-to-end&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;Demonstrates full-stack range: bash hooks, JSON state design, PyQt6 desktop UI, Win32 + IVirtualDesktopManager COM, PyInstaller packaging, and a Claude Code plugin manifest — all built solo and shipped as one cohesive piece.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#526C96;font-style:italic;&#39;&gt;“Solo dev who can ship a desktop app, a plugin, and a marketplace listing in one weekend.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="30" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-2" value="&lt;span style=&#39;font-size:11px;color:#638860;letter-spacing:2px;&#39;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;Robust under realistic failure modes&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;Five lifecycle hooks routed through one bash script. Optional jq with a sed fallback. PID-alive eviction when SessionEnd never fires. Per-instance state plus an aggregate tile. Defensive IPC across separate processes.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#638860;font-style:italic;&#39;&gt;“I see how this stays correct when something obvious breaks — that&amp;#x27;s the part most demos skip.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="590" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-aud-3" value="&lt;span style=&#39;font-size:11px;color:#796394;letter-spacing:2px;&#39;&gt;FOR NON-TECHNICAL AUDIENCES&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#39;font-size:17px;color:#1E2933;&#39;&gt;A floating timer that never lies&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#3A4555;&#39;&gt;One small tile sits on top of every window. It shows a row for each Claude conversation, glows when one finishes, and clicking a row jumps you straight to that project. Nothing else to learn.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:12px;color:#796394;font-style:italic;&#39;&gt;“Oh — the green pill turning red is when I should reply. Got it.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1">
                    <mxGeometry x="1150" y="540" width="520" height="220" as="geometry"/>
                </mxCell>
                <mxCell id="bet-footer" value="&lt;b style=&#39;color:#3F5566;letter-spacing:1px;font-size:11px;&#39;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;Personal tools shouldn&amp;#x27;t need to be SaaS. A focused 1700-line PyQt tile and a 100-line bash script can outperform commercial &amp;#x27;AI session managers&amp;#x27; for one engineer who just wants to know when Claude is done.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="800" width="1380" height="80" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
    <diagram name="Portfolio (P)" id="p-portfolio">
        <mxGraphModel dx="1461" dy="788" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" background="#1a2235" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="hdr-title" value="TTYL — &amp;quot;Talk To You Later&amp;quot;" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="20" width="1640" height="46" as="geometry"/>
                </mxCell>
                <mxCell id="hdr-sub" value="Knows when Claude is working vs. waiting, so you don&amp;#x27;t lose your speed-up cache or miss a finished reply" style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1">
                    <mxGeometry x="30" y="72" width="1640" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="problem-strip" value="&lt;b style=&#39;color:#9F2D43;letter-spacing:1px;font-size:11px;&#39;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#39;font-size:14px;color:#3A4555;&#39;&gt;Claude has a speed-up cache that resets every 5 minutes. If you don&amp;#x27;t reply in time, your next message gets slow and expensive. Worse: with several Claude tabs open at once, it&amp;#x27;s hard to tell which is about to expire — or which is even still thinking.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="160" y="120" width="1380" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="flow-header" value="How it works" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1">
                    <mxGeometry x="30" y="222" width="1640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-1" value="&lt;span style=&#39;font-size:10px;color:#526C96;letter-spacing:2px;&#39;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Claude says something&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Claude tells the plugin&lt;br&gt;what just happened —&lt;br&gt;started, replied, or stopped.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="20" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-2" value="&lt;span style=&#39;font-size:10px;color:#638860;letter-spacing:2px;&#39;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Tiny note saved&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Each chat has its own&lt;br&gt;little file remembering&lt;br&gt;what it&amp;#x27;s currently doing.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="365" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-3" value="&lt;span style=&#39;font-size:10px;color:#796394;letter-spacing:2px;&#39;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Tile checks the notes&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;The floating tile rechecks&lt;br&gt;every file once a second&lt;br&gt;and drops gone-away chats.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="710" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-4" value="&lt;span style=&#39;font-size:10px;color:#966B51;letter-spacing:2px;&#39;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Coloured pill ticks&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Each row glows green,&lt;br&gt;then yellow, then red —&lt;br&gt;and flashes when finished.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1055" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-stage-5" value="&lt;span style=&#39;font-size:10px;color:#958769;letter-spacing:2px;&#39;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#39;font-size:18px;color:#1E2933;&#39;&gt;Click to jump back&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#39;font-size:11px;color:#5A6470;&#39;&gt;Click any row and your&lt;br&gt;cursor lands right back&lt;br&gt;in that project&amp;#x27;s window.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1">
                    <mxGeometry x="1400" y="265" width="280" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-1" target="pitch-stage-2" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-2" target="pitch-stage-3" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-3" target="pitch-stage-4" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" source="pitch-stage-4" target="pitch-stage-5" edge="1">
                    <mxGeometry relative="1" as="geometry"/>
