        <mxCell id="outputs-header" value="Three audiences. One artifact." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="495" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A working app, not a pitch deck&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Real voice ID running on the phone, real on-device AI, real cloud AI when you ask for it. The hard parts are built and the rest is in flight.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“Specific, hard, and finished — not vapor.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;See how it&amp;#x27;s all put together&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;How the listener works, how the gate decides what to keep, why some AI runs on the phone and some in the cloud — every interesting choice is documented. Walk in and start contributing.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“Onboarding in a coffee, not a week.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;FOR YOUR PARTNER &amp;amp; THERAPIST&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;It&amp;#x27;s a coach, not a microphone in your home&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Only your enrolled voice is ever saved. Everyone else&amp;#x27;s audio is dropped before it touches disk. The phone is the only place audio lives. You can turn it off mid-conversation.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“Now I get why this is different from Alexa.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;How people fight, pull away, and come back together follows a real pattern — but you have to catch yourself in the act. Ainsworth fills the gap between therapy and the moments you actually live.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
