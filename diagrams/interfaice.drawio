<?xml version="1.0" encoding="UTF-8"?>
<!-- Portfolio architecture diagram — INTERFaiCE (engineering overview, no business detail) -->
<mxfile host="app.diagrams.net" modified="2026-07-02T00:00:00.000Z" agent="portfolio" version="24.0.0">
<diagram name="Portfolio (T)" id="t-portfolio">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hdr-title" value="INTERFaiCE" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="20" width="1640" height="46" as="geometry" /></mxCell>
        <mxCell id="hdr-sub" value="A real-time AI that answers scam calls, and a data trail that names who leaked you." style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1"><mxGeometry x="30" y="72" width="1640" height="26" as="geometry" /></mxCell>
        <mxCell id="problem-strip" value="&lt;b style=&#x27;color:#9F2D43;letter-spacing:1px;font-size:11px;&#x27;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Your number and email get sold and leaked, and then the scam calls start. Spam filters are reactive, and you can never prove which company let your data escape — so no one is ever held to account.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="120" width="1380" height="80" as="geometry" /></mxCell>
        <mxCell id="flow-header" value="How the call gets answered" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="222" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-1" value="&lt;span style=&#x27;font-size:10px;color:#526C96;letter-spacing:2px;&#x27;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Call comes in&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Twilio Media Streams bridges&lt;br&gt;the live call audio to the&lt;br&gt;service over a WebSocket.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="20" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-2" value="&lt;span style=&#x27;font-size:10px;color:#638860;letter-spacing:2px;&#x27;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Hear&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Deepgram streams speech-to-text&lt;br&gt;in real time — with local&lt;br&gt;Whisper wired in as a&lt;br&gt;self-hosted fallback.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="365" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-3" value="&lt;span style=&#x27;font-size:10px;color:#796394;letter-spacing:2px;&#x27;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Think&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;An AI persona (Gemini Live)&lt;br&gt;decides what to say. A human&lt;br&gt;can steer it live, mid-call.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="710" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-4" value="&lt;span style=&#x27;font-size:10px;color:#966B51;letter-spacing:2px;&#x27;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Speak&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Cartesia (or local Kokoro) TTS&lt;br&gt;replies in a natural voice with&lt;br&gt;sub-second latency, so you&lt;br&gt;never take the call.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1055" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-5" value="&lt;span style=&#x27;font-size:10px;color:#958769;letter-spacing:2px;&#x27;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;Attribute the leak&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Each company gets a unique&lt;br&gt;masked address. The first&lt;br&gt;unexpected sender on it names&lt;br&gt;the leaker — metadata only.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1400" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-1" target="pitch-stage-2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-2" target="pitch-stage-3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-3" target="pitch-stage-4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-4" target="pitch-stage-5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="produces-label" value="↓   why it matters   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1"><mxGeometry x="700" y="455" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="outputs-header" value="Three views. One system." style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="495" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;FOR RECRUITERS &amp;amp; STAKEHOLDERS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Real-time voice AI, not a chatbot&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Sub-second turn-taking over a live phone call, with a fully self-hostable local-inference path validated on consumer hardware. The hard latency and audio problems are built and working.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“Live telephony AI is genuinely hard.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;FOR ENGINEERS &amp;amp; COLLABORATORS&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A streaming pipeline with real invariants&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;A Twilio&amp;#8596;STT&amp;#8596;LLM&amp;#8596;TTS bridge with voiceprint matching, two-party-consent gating written into the code, append-only ledgers enforced at the database, and a Cloudflare Email Worker that acts as a first-hop leak tripwire.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“Privacy is engineered, not promised.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;FOR THE PERSON BEING CALLED&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;It answers so you don&amp;#x27;t have to&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;The AI takes the scam call live, and the alias system finally gives you proof of which company let your data out — turning a nuisance into accountability.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“The scammer argues with a robot now.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BET&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Spam defense today is reactive and anonymous. INTERFaiCE makes it active — an AI takes the call — and accountable — the leak finally has a name.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
<diagram name="Portfolio (P)" id="p-portfolio">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="0" arrows="0" fold="0" page="1" pageScale="1" pageWidth="1700" pageHeight="1050" math="0" shadow="0" background="#1a2235">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="hdr-title" value="INTERFaiCE" style="text;html=1;fontSize=34;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="20" width="1640" height="46" as="geometry" /></mxCell>
        <mxCell id="hdr-sub" value="A robot answers the scam calls for you — and shows you who leaked your info." style="text;html=1;fontSize=16;fontStyle=2;align=center;verticalAlign=middle;fontColor=#5A6470;" parent="1" vertex="1"><mxGeometry x="30" y="72" width="1640" height="26" as="geometry" /></mxCell>
        <mxCell id="problem-strip" value="&lt;b style=&#x27;color:#9F2D43;letter-spacing:1px;font-size:11px;&#x27;&gt;THE PROBLEM&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Companies sell and leak your phone number and email, and then the scam calls never stop. You block one and another shows up, and you can never prove which company let your details out in the first place.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEBEF;strokeColor=#F38BA8;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="120" width="1380" height="80" as="geometry" /></mxCell>
        <mxCell id="flow-header" value="How the call gets answered" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="222" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-1" value="&lt;span style=&#x27;font-size:10px;color:#526C96;letter-spacing:2px;&#x27;&gt;STEP 1&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;The call comes in&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;When a call arrives, it&amp;#x27;s&lt;br&gt;handed straight to the&lt;br&gt;AI instead of ringing you.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="20" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-2" value="&lt;span style=&#x27;font-size:10px;color:#638860;letter-spacing:2px;&#x27;&gt;STEP 2&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;It listens&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;It turns what the caller&lt;br&gt;says into text, instantly,&lt;br&gt;as they speak.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="365" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-3" value="&lt;span style=&#x27;font-size:10px;color:#796394;letter-spacing:2px;&#x27;&gt;STEP 3&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;It decides what to say&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;An AI plays a character and&lt;br&gt;keeps the caller busy. You&lt;br&gt;can jump in and steer it.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="710" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-4" value="&lt;span style=&#x27;font-size:10px;color:#966B51;letter-spacing:2px;&#x27;&gt;STEP 4&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;It talks back&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;It replies out loud in a&lt;br&gt;natural voice, fast enough&lt;br&gt;to hold a real conversation&lt;br&gt;— so you never pick up.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDEEE4;strokeColor=#FAB387;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1055" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-stage-5" value="&lt;span style=&#x27;font-size:10px;color:#958769;letter-spacing:2px;&#x27;&gt;STEP 5&lt;/span&gt;&lt;br&gt;&lt;b style=&#x27;font-size:18px;color:#1E2933;&#x27;&gt;It catches the leak&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:11px;color:#5A6470;&#x27;&gt;Every company gets its own&lt;br&gt;disposable address. If mail&lt;br&gt;shows up from anyone else,&lt;br&gt;you know exactly who leaked it.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FDF8ED;strokeColor=#F9E2AF;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=10;" parent="1" vertex="1"><mxGeometry x="1400" y="265" width="280" height="170" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-1" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-1" target="pitch-stage-2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-2" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-2" target="pitch-stage-3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-3" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-3" target="pitch-stage-4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="pitch-flow-arrow-4" value="" style="endArrow=classic;html=1;strokeColor=#7E8590;strokeWidth=3;edgeStyle=none;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" parent="1" edge="1" source="pitch-stage-4" target="pitch-stage-5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="produces-label" value="↓   why it matters   ↓" style="text;html=1;fontSize=14;fontStyle=1;align=center;verticalAlign=middle;fontColor=#7E8590;" parent="1" vertex="1"><mxGeometry x="700" y="455" width="300" height="30" as="geometry" /></mxCell>
        <mxCell id="outputs-header" value="What it means for you" style="text;html=1;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;fontColor=#E5E7EB;" parent="1" vertex="1"><mxGeometry x="30" y="495" width="1640" height="30" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-1" value="&lt;span style=&#x27;font-size:11px;color:#526C96;letter-spacing:2px;&#x27;&gt;IF YOU ARE HIRING&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;A live AI phone call, actually working&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;Holding a real, spoken conversation over a phone line with almost no delay is one of the harder things to build — and it runs, including a version that works on your own hardware.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#526C96;font-style:italic;&#x27;&gt;“This is a hard thing, done.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E5EEFD;strokeColor=#89B4FA;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="30" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-2" value="&lt;span style=&#x27;font-size:11px;color:#638860;letter-spacing:2px;&#x27;&gt;IF YOU BUILD SOFTWARE&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;Privacy built into the plumbing&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;The phone line, the listening, the thinking and the talking are all chained together, with the privacy rules baked into the code and the database instead of being a promise on a page.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#638860;font-style:italic;&#x27;&gt;“The rules are enforced, not stated.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EBF8EA;strokeColor=#A6E3A1;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="590" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="pitch-aud-3" value="&lt;span style=&#x27;font-size:11px;color:#796394;letter-spacing:2px;&#x27;&gt;IF YOU KEEP GETTING SPAM&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;b style=&#x27;font-size:17px;color:#1E2933;&#x27;&gt;It answers so you don&amp;#x27;t have to&lt;/b&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#3A4555;&#x27;&gt;The robot handles the scam call for you, and the disposable-address trick finally tells you which company leaked your details — so the annoyance turns into an answer.&lt;/span&gt;&lt;br&gt;&lt;br&gt;&lt;span style=&#x27;font-size:12px;color:#796394;font-style:italic;&#x27;&gt;“Let the scammer waste the robot&amp;#x27;s time.”&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBFD;strokeColor=#CBA6F7;strokeWidth=2;align=center;verticalAlign=middle;shadow=1;arcSize=8;spacing=15;" parent="1" vertex="1"><mxGeometry x="1150" y="540" width="520" height="220" as="geometry" /></mxCell>
        <mxCell id="bet-footer" value="&lt;b style=&#x27;color:#3F5566;letter-spacing:1px;font-size:11px;&#x27;&gt;THE BIG IDEA&lt;/b&gt;&lt;br&gt;&lt;span style=&#x27;font-size:14px;color:#3A4555;&#x27;&gt;Right now, fighting spam means blocking and hoping — and no one is ever blamed. INTERFaiCE flips both: a robot takes the call, and the leak finally gets a name.&lt;/span&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F4F6FA;strokeColor=#A8B3C2;dashed=1;strokeWidth=2;fontSize=14;align=center;verticalAlign=middle;shadow=1;arcSize=8;" parent="1" vertex="1"><mxGeometry x="160" y="800" width="1380" height="80" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
